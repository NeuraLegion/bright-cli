FROM node:24-alpine
# Verify that @brightsec/node-libcurl@5.0.14-0 ships a linux-arm64-musl
# prebuilt binary. Install in a project directory (required by npm) WITHOUT
# a native toolchain — build succeeds only if the prebuilt binary is present.
RUN mkdir /verify && \
    cd /verify && \
    npm init -y && \
    npm install @brightsec/node-libcurl@5.0.14-0 && \
    node -e "require('@brightsec/node-libcurl')" && \
    echo "node-libcurl loaded successfully"
